# Copy this file to `.env` and fill in the values.
# Do NOT commit `.env`.

# Required — JWT signing key. Any long random string for local dev.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Optional — Postgres connection string. Leave unset to fall back to local SQLite (learning.db).
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# CORS / cookie origin for the frontend. Default for local dev is fine.
FRONTEND_URL=http://localhost:3000

# Transactional email (password reset). Create a Resend account and API key.
# Password reset flows will fail without this, but the rest of the app runs.
RESEND_API_KEY=

# Recipient for the daily automated DB backup email (see backend/backup_db.py).
BACKUP_EMAIL=

# Set to "true" to return 503 on all /api/* routes (health check still works).
# MAINTENANCE_MODE=false
